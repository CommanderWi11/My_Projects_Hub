# Projects Hub auth — REFERENCE ONLY
# Do not edit this file with real secrets. Run `node setup-auth.mjs` instead;
# it generates the real values and writes them to:
#   ~/.config/my-projects-hub/.env   (outside this iCloud-synced repo)
#
# The launcher reads that file (override its path with HUB_ENV_FILE=/path/.env).
# With NONE of these set, the launcher runs in local-only mode (no remote access).

HUB_USERNAME=              # your login username (an email)
HUB_PASSWORD_SALT=         # hex salt (generated)
HUB_PASSWORD_HASH=         # scrypt hash of your password (generated)
SESSION_SECRET=            # random 32-byte hex, signs the session cookie (generated)
TOTP_SECRET=               # base32 secret for your authenticator app (generated)

# Trusted public base URL — used to build password-reset links. REQUIRED for
# remote reset emails (never derived from the request Host, which is spoofable).
PUBLIC_URL=                # e.g. https://bobmac.tail6dba15.ts.net

# Outgoing email for the "set/reset password via link" flow (run setup-smtp.mjs).
SMTP_HOST=                 # e.g. mail.gmx.com
SMTP_PORT=                 # e.g. 465 (implicit TLS)
SMTP_USER=                 # e.g. luisnavm@gmx.com
SMTP_PASS=                 # GMX app-password
MAIL_FROM=                 # usually same as SMTP_USER
MAIL_TO=                   # where reset links are sent (your address)
